{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "verdict",
    "summary",
    "findings",
    "requires_verify",
    "coverage",
    "residual_risks"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "plan-review-output/v1"
    },
    "verdict": {
      "type": "string",
      "enum": [
        "approve",
        "needs-attention"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "severity",
          "readiness_effect",
          "requires_re_review",
          "title",
          "plan_file",
          "line_start",
          "line_end",
          "evidence",
          "risk",
          "recommendation",
          "options"
        ],
        "properties": {
          "severity": {
            "type": "string",
            "enum": [
              "critical",
              "high",
              "medium",
              "low"
            ]
          },
          "readiness_effect": {
            "type": "string",
            "enum": [
              "blocks-implementation",
              "should-fix-before-start",
              "can-fix-during-implementation"
            ]
          },
          "requires_re_review": {
            "type": "boolean"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "plan_file": {
            "type": "string",
            "minLength": 1
          },
          "line_start": {
            "type": "integer",
            "minimum": 1
          },
          "line_end": {
            "type": "integer",
            "minimum": 1
          },
          "evidence": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/evidence"
            }
          },
          "risk": {
            "type": "string",
            "minLength": 1
          },
          "recommendation": {
            "type": "string",
            "minLength": 1
          },
          "options": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/option"
            }
          }
        }
      }
    },
    "requires_verify": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/requires_verify"
      }
    },
    "coverage": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/coverage"
      }
    },
    "residual_risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "summary"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "plan",
            "code",
            "test",
            "doc",
            "tool-output"
          ]
        },
        "path": {
          "type": "string"
        },
        "line_start": {
          "type": "integer",
          "minimum": 1
        },
        "line_end": {
          "type": "integer",
          "minimum": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "option": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "change",
        "tradeoff"
      ],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "change": {
          "type": "string",
          "minLength": 1
        },
        "tradeoff": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "requires_verify": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "question",
        "why_it_matters",
        "suggested_check",
        "blocks_approval",
        "related_refs"
      ],
      "properties": {
        "question": {
          "type": "string",
          "minLength": 1
        },
        "why_it_matters": {
          "type": "string",
          "minLength": 1
        },
        "suggested_check": {
          "type": "string",
          "minLength": 1
        },
        "blocks_approval": {
          "type": "boolean"
        },
        "related_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "coverage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "area",
        "status",
        "evidence",
        "notes"
      ],
      "properties": {
        "area": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "checked",
            "partially-checked",
            "not-applicable"
          ]
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "notes": {
          "type": "string"
        }
      }
    }
  }
}
